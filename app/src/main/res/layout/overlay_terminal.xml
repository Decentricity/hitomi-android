<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/hitomiTerminalTitlePill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/beos_titlepill_bg_terminal"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="6dp"
        android:paddingTop="3dp"
        android:paddingRight="6dp"
        android:paddingBottom="3dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/beos_title_button_bg" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="3dp"
            android:background="@drawable/beos_title_button_bg" />

        <TextView
            android:id="@+id/hitomiTerminalTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Terminal"
            android:textColor="#51FF51"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/hitomiTerminalClose"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@android:color/transparent"
            android:contentDescription="Close terminal window"
            android:padding="2dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#51FF51" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="268dp"
        android:layout_height="220dp"
        android:layout_marginTop="-1dp"
        android:background="@drawable/beos_window_body_bg"
        android:orientation="vertical"
        android:padding="6dp">

        <TextView
            android:id="@+id/hitomiTerminalStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#101010"
            android:padding="4dp"
            android:text="Idle"
            android:textColor="#7DFF7D"
            android:textSize="10sp"
            android:textStyle="bold"
            android:typeface="monospace" />

        <ScrollView
            android:id="@+id/hitomiTerminalScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:background="#050505"
            android:fillViewport="true">

            <TextView
                android:id="@+id/hitomiTerminalTranscript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="Hitomi's Termux activity will appear here."
                android:textColor="#8DFF8D"
                android:textSize="11sp"
                android:typeface="monospace" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
